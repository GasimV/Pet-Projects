# =============================================================================
# MLOps-LlamaIndex-Lab — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env      (Linux/Mac)
#   copy .env.example .env    (Windows)
# =============================================================================

# --- LLM Provider Settings ---------------------------------------------------

# Supported: "huggingface" (local), "openai", "ollama"
#LLM_PROVIDER=huggingface
LLM_PROVIDER=ollama
# Model identifier — change to match your provider
#LLM_MODEL=google/gemma-3-1b-it
LLM_MODEL=gemma3:1b
# Only needed for cloud providers (OpenAI, etc.)
LLM_API_KEY=
# For Ollama or custom endpoints
# - Python venv (app runs on host):    http://localhost:11434
# - Docker Compose (app runs in container): http://host.docker.internal:11434
LLM_API_BASE=http://localhost:11434

# --- Embedding Model ---------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3

# --- Qdrant Vector Store -----------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# --- Chunking ----------------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- App Settings ------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
UPLOAD_DIR=data/uploads

# --- Docker internal (used inside containers) --------------------------------
# When running in Docker, Qdrant is accessed via service name
# QDRANT_HOST=qdrant
