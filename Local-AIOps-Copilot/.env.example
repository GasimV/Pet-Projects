# ─────────────────────────────────────────────
# Local-AIOps-Copilot  —  Environment Config
# ─────────────────────────────────────────────
# Copy to .env and adjust for your machine.

# ── Inference Backend ──────────────────────────
# Options: mock | ollama | vllm | triton
LLM_BACKEND=mock

# Ollama (dev machine fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:270m

# vLLM (GPU machine, primary)
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Triton (GPU machine, alternative)
TRITON_HTTP_URL=http://localhost:8001
TRITON_GRPC_URL=localhost:8002
TRITON_MODEL=llama-3.1-8b

# ── Common LLM Settings ───────────────────────
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_STREAM=true

# ── Embedding Backend ─────────────────────────
# Options: mock | ollama | sentence-transformers
EMBEDDING_BACKEND=mock
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Service Ports ─────────────────────────────
API_GATEWAY_PORT=8080
FRONTEND_PORT=8501
AGENT_SERVICE_PORT=50051
RAG_SERVICE_PORT=50052
MCP_SERVER_PORT=50053
EVAL_SERVICE_PORT=50054
RELEASE_CONTROLLER_PORT=50055

# ── Infrastructure ────────────────────────────
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
POSTGRES_URL=postgresql://copilot:copilot@localhost:5432/copilot
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Observability ─────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9093
LOGSTASH_PORT=5044

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Environment Mode ──────────────────────────
# Options: dev | gpu | production
ENVIRONMENT=dev
