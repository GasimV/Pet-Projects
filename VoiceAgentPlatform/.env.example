PROJECT_NAME=voice-agent-platform
ENVIRONMENT=local
LOG_LEVEL=INFO
RUNTIME_PROFILE=local-cpu

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
ORCHESTRATOR_GRPC_HOST=session-orchestrator
ORCHESTRATOR_GRPC_PORT=50051
ORCHESTRATOR_HTTP_PORT=8081

REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql+asyncpg://voice:voice@postgres:5432/voice_platform
QDRANT_URL=http://qdrant:6333

LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=0123456789abcdef0123456789abcdef

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=gemma3:270m
OLLAMA_EMBED_MODEL=bge-m3:latest
OLLAMA_TTS_MODEL=
ENABLE_OLLAMA=true
ENABLE_VLLM=false
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

STT_MODEL=tiny.en
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_CHUNK_MS=250

TTS_PROVIDER=kokoro
TTS_VOICE=af_heart
TTS_DEVICE=cpu
TTS_SPEED=1.0
TTS_LANG_CODE=a
TTS_KOKORO_REPO=hexgrad/Kokoro-82M

TEMPORAL_TARGET=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=voice-platform

KNOWLEDGE_DIR=/workspace/knowledge
DEFAULT_DOMAIN_PACK=starship
SESSION_EVENT_CHANNEL=voice-platform.session-events
SESSION_STREAM_PREFIX=voice-platform:session
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_PORT=9464
