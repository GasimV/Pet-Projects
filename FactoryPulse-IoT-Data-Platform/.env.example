# ============================================================
# FactoryPulse IoT Data Platform — Environment Configuration
# Copy to .env and adjust as needed.
# ============================================================

# ---- Kafka ----
KAFKA_BROKER=kafka:9092
KAFKA_EXTERNAL_PORT=29092
KAFKA_TOPIC_TELEMETRY=factory.telemetry.raw
KAFKA_TOPIC_ALERTS=factory.alerts
KAFKA_TOPIC_INCIDENTS=factory.incidents

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_RAW=factory-raw
MINIO_BUCKET_CURATED=factory-curated
MINIO_BUCKET_MLFLOW=mlflow-artifacts

# ---- Iceberg ----
ICEBERG_CATALOG_URI=thrift://iceberg-rest:8181
ICEBERG_WAREHOUSE=s3a://factory-curated/iceberg

# ---- ClickHouse ----
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DB=factory_pulse

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Qdrant ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=incidents

# ---- FastAPI ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Airflow ----
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@airflow-postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=factory-pulse-secret

# ---- Spark ----
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g

# ---- Flink ----
FLINK_JOBMANAGER_HOST=flink-jobmanager
FLINK_JOBMANAGER_PORT=8081

# ---- Prometheus / Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- MLflow ----
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ---- Marquez (OpenLineage) ----
MARQUEZ_HOST=marquez
MARQUEZ_PORT=5000
OPENLINEAGE_URL=http://marquez-api:5000

# ---- Great Expectations ----
GE_DATA_CONTEXT_ROOT=great_expectations

# ---- Embedding Model ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Simulator ----
SIMULATOR_DEVICE_COUNT=10
SIMULATOR_INTERVAL_MS=2000
SIMULATOR_ANOMALY_RATE=0.05

# ---- Streaming Engine Toggle ----
# Options: spark | flink
STREAMING_ENGINE=spark
